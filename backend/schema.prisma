// This file is automatically generated by Keystone, do not modify it manually.
// Modify your Keystone config when you want to change this.

datasource postgresql {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String         @id @default(cuid())
  name                String         @default("")
  email               String         @unique @default("")
  password            String
  role                UserRoleType?  @default(USER)
  ownedCars           Car[]          @relation("Car_dealer")
  conversations       Conversation[] @relation("Conversation_participants")
  wishlist            WishList?      @relation("User_wishlist", fields: [wishlistId], references: [id])
  wishlistId          String?        @unique @map("wishlist")
  createdAt           DateTime?      @default(now())
  from_Message_sender Message[]      @relation("Message_sender")
}

model Car {
  id                 String     @id @default(cuid())
  brand              Brand?     @relation("Car_brand", fields: [brandId], references: [id])
  brandId            String?    @map("brand")
  model              Model?     @relation("Car_model", fields: [modelId], references: [id])
  modelId            String?    @map("model")
  year               Int?
  fuelType           FuelType?  @relation("Car_fuelType", fields: [fuelTypeId], references: [id])
  fuelTypeId         String?    @map("fuelType")
  price              Decimal?   @postgresql.Decimal(12, 3)
  images             Image[]    @relation("Car_images")
  dealer             User?      @relation("Car_dealer", fields: [dealerId], references: [id])
  dealerId           String?    @map("dealer")
  slug               String     @unique @default("")
  createdAt          DateTime?  @default(now())
  from_WishList_cars WishList[] @relation("WishList_cars")

  @@index([brandId])
  @@index([modelId])
  @@index([fuelTypeId])
  @@index([dealerId])
}

model Image {
  id              String  @id @default(cuid())
  image_id        String?
  image_filesize  Int?
  image_width     Int?
  image_height    Int?
  image_extension String?
  from_Car_images Car[]   @relation("Car_images")
}

model Brand {
  id     String  @id @default(cuid())
  name   String  @default("")
  models Model[] @relation("Model_brand")
  cars   Car[]   @relation("Car_brand")
}

model Model {
  id      String  @id @default(cuid())
  name    String  @default("")
  brand   Brand?  @relation("Model_brand", fields: [brandId], references: [id])
  brandId String? @map("brand")
  cars    Car[]   @relation("Car_model")

  @@index([brandId])
}

model FuelType {
  id   String @id @default(cuid())
  name String @default("")
  cars Car[]  @relation("Car_fuelType")
}

model Conversation {
  id           String    @id @default(cuid())
  participants User[]    @relation("Conversation_participants")
  messages     Message[] @relation("Message_conversation")
  createdAt    DateTime? @default(now())
}

model Message {
  id             String        @id @default(cuid())
  sender         User?         @relation("Message_sender", fields: [senderId], references: [id])
  senderId       String?       @map("sender")
  conversation   Conversation? @relation("Message_conversation", fields: [conversationId], references: [id])
  conversationId String?       @map("conversation")
  content        String        @default("")
  createdAt      DateTime?     @default(now())

  @@index([senderId])
  @@index([conversationId])
}

model WishList {
  id   String @id @default(cuid())
  user User?  @relation("User_wishlist")
  cars Car[]  @relation("WishList_cars")
}

enum UserRoleType {
  USER
  ADMIN
}
